# elastic-mcp-triage — configuration template
# Copy to .env and fill in your values, or run:  python install.py

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
ELASTIC_URL=https://localhost:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=
# Set to "true" only if your cluster has a CA-trusted certificate.
ELASTIC_VERIFY_SSL=false
ELASTIC_INDEX=.alerts-security.alerts-default
ELASTIC_TIMEOUT=30
# Comma-separated event indices (used for related-events lookup)
# ELASTIC_EVENT_INDICES=logs-*,filebeat-*,winlogbeat-*,auditbeat-*

# ---------------------------------------------------------------------------
# Threat intelligence  (leave blank to disable)
# ---------------------------------------------------------------------------
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
THREAT_INTEL_TIMEOUT=10

# ---------------------------------------------------------------------------
# AI verdict backend
# Set AI_PROVIDER to one of: claude | ollama | openai_compat | none
# ---------------------------------------------------------------------------
AI_PROVIDER=none

# --- Anthropic Claude (AI_PROVIDER=claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Ollama local LLM (AI_PROVIDER=ollama) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- OpenAI-compatible API (AI_PROVIDER=openai_compat) ---
# Works with: LM Studio, vLLM, Groq, Together AI, Mistral API, etc.
OPENAI_COMPAT_URL=http://localhost:1234/v1
OPENAI_COMPAT_KEY=
OPENAI_COMPAT_MODEL=mistral

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Set to your ngrok / reverse-proxy URL so the MCP endpoint is shown correctly
# PUBLIC_URL=https://your-tunnel.ngrok-free.app

# ---------------------------------------------------------------------------
# Asset inventory
# ---------------------------------------------------------------------------
ASSET_INVENTORY_PATH=assets.yml

# ---------------------------------------------------------------------------
# Related events window
# ---------------------------------------------------------------------------
RELATED_EVENTS_WINDOW_MIN=15
RELATED_EVENTS_MAX=50
